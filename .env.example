# Copy this file to .env.local and fill in your Supabase project's values
# (Project Settings → API in the Supabase dashboard).
#
# If these are left unset, the app automatically falls back to the static
# mock data in src/data.ts — nothing breaks, it just won't persist actions.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
